# ---- Runtime environment -----------------------------------------------
NODE_ENV=development
PORT=3042
LOG_LEVEL=info
BODY_LIMIT=100kb

# Express trust-proxy. 'loopback' (dev), 1 (nginx), 2 (Cloudflare + nginx).
TRUST_PROXY=loopback

# Comma-separated list of allowed CORS origins, or "*" for open, or "" to disable.
# Leave empty for same-origin-only deployments (EJS views, nginx reverse proxy).
CORS_ORIGINS=

# ---- AI image providers ------------------------------------------------
STABILITY_KEY=
OPENAI_KEY=
GOOGLE_API_KEY=
FAL_KEY=
REPLICATE_TOKEN=

# ---- Supabase (application-layer DB client) ----------------------------
SUPABASE_URL=
SUPABASE_KEY=service_role_...

# ---- Postgres direct (for node-pg-migrate) -----------------------------
# Use the same Postgres you point Supabase at. Required in production.
DATABASE_URL=postgres://user:pass@host:5432/postgres

# ---- Redis (rate limit + BullMQ) ---------------------------------------
# Required in production. Leave empty in dev to disable Redis-backed features.
REDIS_URL=redis://localhost:6379

# ---- Cloudflare --------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_TOKEN=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ---- Cloudflare R2 (S3-compatible image storage) -----------------------
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=xcap-data
R2_PUBLIC_URL=

# ---- Auth --------------------------------------------------------------
CRON_SECRET=

# ---- Observability -----------------------------------------------------
SENTRY_DSN=

# ---- Timeouts (ms) -----------------------------------------------------
PROVIDER_TIMEOUT_MS=30000
CLOUDFLARE_TIMEOUT_MS=15000
TURNSTILE_TIMEOUT_MS=5000
