{
  "name": "@rankbase/imgrank",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:client": "npm --prefix client run build",
    "build:all": "npm run build && npm run build:client",
    "start": "node dist/index.js",
    "dev": "ts-node -p tsconfig.json src/index.ts",
    "tag-images": "IMAGE_TABLE=images NSFW=false ts-node ../../packages/core/src/scripts/tag-images.ts"
  },
  "dependencies": {
    "@rankbase/core": "workspace:*",
    "@aws-sdk/client-s3": "^3.1040.0",
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.101.1",
    "bullmq": "^5.75.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}